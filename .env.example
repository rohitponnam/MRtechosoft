DATABASE_URL="postgresql://user:password@localhost:5432/mrtechnosoft"
# Optional direct runtime URL when DATABASE_URL is a prisma+postgres proxy URL.
DIRECT_DATABASE_URL=""
SESSION_SECRET="replace-with-a-long-random-secret"

# First admin account is created on initial login when these credentials match.
ADMIN_NAME="Platform Admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-strong-password"

# Stripe Checkout. Without these values, the app uses an explicit demo checkout.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# CRM: configure a generic webhook or HubSpot private app token.
CRM_WEBHOOK_URL=""
CRM_WEBHOOK_SECRET=""
HUBSPOT_ACCESS_TOKEN=""

# Optional external chatbot endpoint. Local deterministic responses work without it.
AI_CHAT_ENDPOINT=""
AI_CHAT_API_KEY=""

# Follow-up email configuration.
CRON_SECRET=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Public company identity. Replace these defaults with official details.
NEXT_PUBLIC_COMPANY_EMAIL="support@mrtechnosoft.com"
NEXT_PUBLIC_COMPANY_PHONE="+1 (720) 339-2386"
NEXT_PUBLIC_COMPANY_PHONE_HREF="+17203392386"
NEXT_PUBLIC_COMPANY_ADDRESS="9800 Mount Pyramid Court, Suite 400, Englewood, Colorado 80112, USA"
NEXT_PUBLIC_COMPANY_WEBSITE="https://www.mrtechnosoft.com"
NEXT_PUBLIC_WHATSAPP_URL="https://wa.me/17209383462"
NEXT_PUBLIC_LINKEDIN_URL="https://www.linkedin.com/company/mrtechnosoft/?viewAsMember=true"
NEXT_PUBLIC_INSTAGRAM_URL="https://www.instagram.com/mrtechnosoft"
NEXT_PUBLIC_FACEBOOK_URL="https://www.facebook.com/MRtechnosoft1/"
